---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<Layout title="Aegis Creation Blog">
  <main>
    <section class="hero">
      <h1>Welcome to Aegis Creation</h1>
      <p>Thoughts, tutorials, and insights on web development, design, and technology.</p>
    </section>

    <section class="posts">
      <h2>Latest Posts</h2>
      <ul class="post-list">
        {sortedPosts.length === 0 ? (
          <li class="no-posts">
            <p>No posts yet. Check back soon!</p>
          </li>
        ) : (
          sortedPosts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.slug}`}>
                {post.data.image && (
                  <img src={post.data.image} alt={post.data.title} class="post-image" />
                )}
                <div class="post-content">
                  <h3>{post.data.title}</h3>
                  <p class="post-date">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  </p>
                  <p class="post-description">{post.data.description}</p>
                  {post.data.tags && (
                    <div class="tags">
                      {post.data.tags.map((tag: string) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))
        )}
      </ul>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    color: white;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .posts h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: #1a202c;
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .post-content {
    padding: 1.5rem;
  }

  .post-content h3 {
    font-size: 1.5rem;
    color: #1a202c;
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.875rem;
    color: #718096;
    margin-bottom: 0.75rem;
  }

  .post-description {
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: #edf2f7;
    color: #667eea;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .no-posts {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem;
    background: #f7fafc;
    border-radius: 12px;
    color: #718096;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .post-list {
      grid-template-columns: 1fr;
    }
  }
</style>