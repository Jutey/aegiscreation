---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Newsletter from '../components/Newsletter.astro';

const featuredPosts = [
  {
    title: "The Rise of Autonomous AI Agents in 2025",
    slug: "autonomous-ai-agents-2025",
    excerpt: "Exploring how autonomous AI agents are reshaping workflows, development, and decision-making across industries.",
    date: "2025-01-15",
    category: "AI Trends",
    image: "/images/ai-agents.jpg",
    readTime: "8 min read"
  },
  {
    title: "Building Production-Ready LLM Applications",
    slug: "production-ready-llm-apps",
    excerpt: "A comprehensive guide to architecting, deploying, and scaling large language model applications.",
    date: "2025-01-12",
    category: "Development",
    image: "/images/llm-apps.jpg",
    readTime: "12 min read"
  },
  {
    title: "RAG vs Fine-Tuning: When to Use What",
    slug: "rag-vs-fine-tuning",
    excerpt: "Understanding the trade-offs between retrieval-augmented generation and model fine-tuning for your use case.",
    date: "2025-01-10",
    category: "Technical Deep Dive",
    image: "/images/rag-finetuning.jpg",
    readTime: "10 min read"
  }
];

const categories = [
  { name: "AI Trends", count: 24, icon: "📈" },
  { name: "Development", count: 18, icon: "💻" },
  { name: "Tools & Reviews", count: 15, icon: "🛠️" },
  { name: "Tutorials", count: 32, icon: "📚" },
  { name: "Industry News", count: 21, icon: "📰" }
];
---

<BaseLayout title="Aegis Creation - AI Tech Blog" description="Your source for cutting-edge AI insights, tutorials, and industry analysis. Stay ahead with Aegis Creation.">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">AI-Powered Insights</span>
      <h1>Navigate the Future of <span class="gradient-text">Artificial Intelligence</span></h1>
      <p class="hero-description">
        Expert analysis, practical tutorials, and breaking news from the frontier of AI technology. 
        Built by AI, curated for humans.
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn-primary">Explore Articles</a>
        <a href="#newsletter" class="btn btn-secondary">Subscribe Free</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">150+</span>
          <span class="stat-label">Articles</span>
        </div>
        <div class="stat">
          <span class="stat-number">50K+</span>
          <span class="stat-label">Readers</span>
        </div>
        <div class="stat">
          <span class="stat-number">Daily</span>
          <span class="stat-label">Updates</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="featured-section">
    <div class="section-header">
      <h2>Featured Articles</h2>
      <a href="/blog" class="view-all">View All →</a>
    </div>
    <div class="posts-grid">
      {featuredPosts.map((post) => (
        <PostCard 
          title={post.title}
          slug={post.slug}
          excerpt={post.excerpt}
          date={post.date}
          category={post.category}
          image={post.image}
          readTime={post.readTime}
        />
      ))}
    </div>
  </section>

  <!-- Categories Section -->
  <section class="categories-section">
    <h2>Explore Topics</h2>
    <div class="categories-grid">
      {categories.map((category) => (
        <a href={`/category/${category.name.toLowerCase().replace(/\s+/g, '-')}`} class="category-card">
          <span class="category-icon">{category.icon}</span>
          <span class="category-name">{category.name}</span>
          <span class="category-count">{category.count} articles</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Ad Placement -->
  <aside class="ad-section">
    <div class="ad-placeholder" data-ad-slot="homepage-mid">
      <span>Advertisement</span>
    </div>
  </aside>

  <!-- Newsletter Section -->
  <section id="newsletter" class="newsletter-section">
    <Newsletter />
  </section>

  <!-- Affiliate Section -->
  <section class="tools-section">
    <div class="section-header">
      <h2>Recommended AI Tools</h2>
      <span class="affiliate-disclosure">Affiliate links help support our content</span>
    </div>
    <div class="tools-grid">
      <a href="#" class="tool-card" data-affiliate="true">
        <div class="tool-logo">🤖</div>
        <h3>Claude Pro</h3>
        <p>Advanced AI assistant for complex tasks</p>
        <span class="tool-cta">Try Free →</span>
      </a>
      <a href="#" class="tool-card" data-affiliate="true">
        <div class="tool-logo">🎨</div>
        <h3>Midjourney</h3>
        <p>Create stunning AI-generated artwork</p>
        <span class="tool-cta">Get Started →</span>
      </a>
      <a href="#" class="tool-card" data-affiliate="true">
        <div class="tool-logo">⚡</div>
        <h3>Cursor AI</h3>
        <p>AI-powered code editor</p>
        <span class="tool-cta">Download →</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(99, 102, 241, 0.2);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background